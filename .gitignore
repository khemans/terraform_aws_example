# Local .terraform directories
**/.terraform/*

# State files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files containing secrets
*.auto.tfvars
secrets.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Lock file (optional: commit for reproducibility — uncomment to ignore)
# .terraform.lock.hcl

# Makefile-generated files
*.tfvars.json
*.tfplan
*-bucket.conf
*.lock.hcl.bak
